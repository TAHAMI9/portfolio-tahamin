# ──────────────────────────────────────────────────────────────────────────────
# FRONTEND ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ──────────────────────────────────────────────────────────────────────────────

# The URL of your backend API server (Node.js/Express)
# Development: http://localhost:5000
# Production:  https://api.tahaminislam.com (your deployed backend URL)
NEXT_PUBLIC_API_URL=http://localhost:5000

# Google Analytics Measurement ID (optional)
# Get this from Google Analytics > Admin > Data Streams
# Example: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# Your Vercel project URL (set automatically by Vercel on deploy)
NEXT_PUBLIC_VERCEL_URL=
