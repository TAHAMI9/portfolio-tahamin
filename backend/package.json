{
  "name": "tahamin-portfolio-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Express.js API backend for Tahamin Islam's portfolio site",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:cluster": "ts-node-dev --respawn --transpile-only src/cluster.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:cluster": "node dist/cluster.js",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "dotenv": "^16.4.5",
    "nodemailer": "^6.9.13",
    "express-validator": "^7.0.1",
    "express-rate-limit": "^7.2.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "typescript": "^5.4.4",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/nodemailer": "^6.4.14",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.12.7",
    "ts-node-dev": "^2.0.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.7.1",
    "@typescript-eslint/parser": "^7.7.1"
  }
}
