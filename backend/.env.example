# ──────────────────────────────────────────────────────────────────────────────
# BACKEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it is already in .gitignore
# ──────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
# The port the Express server will run on
PORT=5000

# ── CORS ─────────────────────────────────────────────────────────────────────
# The URL of your frontend (Next.js). 
# Development:  http://localhost:3000
# Production:   https://tahaminislam.com   (your real domain)
FRONTEND_URL=http://localhost:3000

# ── Email (Nodemailer via Gmail) ──────────────────────────────────────────────
# Your Gmail address that will SEND contact form emails
EMAIL_USER=thahaminislam@gmail.com

# Gmail App Password (NOT your normal Gmail password)
# How to get one:
#   1. Go to your Google Account → Security
#   2. Enable 2-Step Verification
#   3. Go to Security → App passwords
#   4. Create an app password for "Mail"
#   5. Paste the 16-character password below (no spaces)
EMAIL_PASS=your_gmail_app_password_here

# The email address where contact form submissions will be RECEIVED
# (This can be the same as EMAIL_USER, or a different address)
EMAIL_RECEIVER=thahaminislam@gmail.com

# ── Email (Alternative: SendGrid) ────────────────────────────────────────────
# If you prefer SendGrid over Gmail, get an API key from sendgrid.com
# and uncomment the lines below. Also update emailService.ts accordingly.
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxx

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Max contact form submissions per IP per window
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes in ms
RATE_LIMIT_MAX=10             # Max 10 requests per window

# ── Environment ──────────────────────────────────────────────────────────────
NODE_ENV=development
